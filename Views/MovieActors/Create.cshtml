@model Spring2026_CS330_Project3_rhhunter.Models.MovieActor

@{
    ViewData["Title"] = "Add Cast Relationship";
}

<div class="page-header">
    <h1>Add Cast Relationship</h1>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>

<div class="form-wrapper mx-auto">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="form-group">
            <label asp-for="MovieId" class="control-label">Movie Title</label>
            <select asp-for="MovieId" class="form-control" asp-items="ViewBag.MovieId"></select>
        </div>
        <div class="form-group">
            <label asp-for="ActorId" class="control-label">Actor Name</label>
            <select asp-for="ActorId" class="form-control" asp-items="ViewBag.ActorId"></select>
        </div>
        <div class="form-group mt-3">
            <input type="submit" value="Create" class="btn btn-primary" />
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}