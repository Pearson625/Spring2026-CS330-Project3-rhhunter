@model Spring2026_CS330_Project3_rhhunter.Models.MovieActor

@{
    ViewData["Title"] = "Cast Details";
}

<div class="page-header">
    <h1>@Model.Movie.Title — @Model.Actor.Name</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>

<div class="table-wrapper p-4 mb-4">
    <div class="row mb-2">
        <div class="col-sm-4 text-muted">Movie</div>
        <div class="col-sm-8">
            <a asp-controller="Movies" asp-action="Details" asp-route-id="@Model.MovieId">@Model.Movie.Title</a>
        </div>
    </div>
    <div class="row mb-2">
        <div class="col-sm-4 text-muted">Actor</div>
        <div class="col-sm-8">
            <a asp-controller="Actors" asp-action="Details" asp-route-id="@Model.ActorId">@Model.Actor.Name</a>
        </div>
    </div>
</div>