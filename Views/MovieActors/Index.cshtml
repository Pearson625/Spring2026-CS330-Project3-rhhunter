@model IEnumerable<Spring2026_CS330_Project3_rhhunter.Models.MovieActor>

@{
    ViewData["Title"] = "Movie Casts";
}

<div class="page-header">
    <h1>Movie Casts</h1>
    <a asp-action="Create" class="btn btn-primary">Add Relationship</a>
</div>

<div class="table-wrapper">
    <table class="table" id="movieCastsTable">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Movie)</th>
                <th>@Html.DisplayNameFor(model => model.Actor)</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Movie.Title)</td>
                    <td>@Html.DisplayFor(modelItem => item.Actor.Name)</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>