@model Spring2026_CS330_Project3_rhhunter.Models.Movie

@{
    ViewData["Title"] = "Delete Movie";
}

<div class="page-header">
    <h1>Delete Movie</h1>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>

<div class="form-wrapper mx-auto">
    <p class="text-center mb-4" style="color: var(--accent);">Are you sure you want to delete this movie?</p>

    <div class="row g-3 mb-4">
        <div class="col-auto">
            @if (Model.Poster != null)
            {
                var base64 = Convert.ToBase64String(Model.Poster);
                <img src="data:image/jpg;base64,@base64" class="poster" />
            }
        </div>
        <div class="col">
            <div class="row mb-2">
                <div class="col-sm-4" style="color: var(--accent);">Title</div>
                <div class="col-sm-8">@Model.Title</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4" style="color: var(--accent);">IMDb</div>
                <div class="col-sm-8">@Model.IMDB</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4" style="color: var(--accent);">Genre</div>
                <div class="col-sm-8">@Model.Genre</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4" style="color: var(--accent);">Release Year</div>
                <div class="col-sm-8">@Model.ReleaseYear</div>
            </div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="row g-2">
            <div class="col">
                <input type="submit" value="Delete" class="btn btn-danger w-100" />
            </div>
            <div class="col">
                <a asp-action="Index" class="btn btn-secondary w-100">Cancel</a>
            </div>
        </div>
    </form>
</div>